{
	"body": {
		"vars": {
			"font-family-default": { "value": "Inter", "type": "font-family" }
		}
	},
	"layout": {
		"vars": {
			"global-margin-top": { "value": "3rem", "unit": "rem", "step": 0.1, "min": 0, "max": 20 },
			"global-margin-bottom": { "value": "3rem", "unit": "rem", "step": 0.1, "min": 0, "max": 20 },
			"global-padding-left": { "value": "3rem", "unit": "rem", "step": 0.1, "min": 0, "max": 20 },
			"global-padding-right": { "value": "3rem", "unit": "rem", "step": 0.1, "min": 0, "max": 20 },
			"global-padding-top": { "value": ["1.5rem", "3rem"], "unit": "rem", "step": 0.1, "min": 0, "max": 20, "suffixes": ["-small", "-large"], "labels": ["pw.option.small", "pw.option.large"] },
			"global-padding-bottom": { "value": ["1.5rem", "3rem"], "unit": "rem", "step": 0.1, "min": 0, "max": 20, "suffixes": ["-small", "-large"], "labels": ["pw.option.small", "pw.option.large"] },
			"global-": { "value": ["1.5rem", "1.5rem", "1.5rem", "1.5rem"], "unit": "rem", "step": 0.1, "min": 0, "max": 20, "suffixes": ["top-left-radius", "top-right-radius", "bottom-left-radius", "bottom-right-radius"], "labels": ["pw.option.top-left", "pw.option.top-right", "pw.option.bottom-left", "pw.option.bottom-right"] }
		}
	},
	"colors": {
		"vars": {
			"body-background": { "value": "#E8E8E8", "type": "color" }
		},
		"colors": {
			"block-background": { "default": "#ffffff", "variant": "#F5F5F5", "variant2": "#1D548B" },
			"block-link": { "default": "#1D548B", "variant": "#1D548B", "variant2": "#8CBAE7" },
			"block-link-hover": { "default": "#1A4E7A", "variant": "#1A4E7A", "variant2": "#7AA9D0" },
			"block-link-active": { "default": "#163F5C", "variant": "#163F5C", "variant2": "#6680A8" }
		}
	}
}
