{
	"body": {
		"vars": {
			"font-family-default": { "value": "Inter", "type": "font-family" },
			"body-background": { "value": "#FFFFFF", "type": "color" }
		}
	},
	"blocks": {
		"vars": {
			"global-margin-top": { "value": "1.5rem", "unit": "rem", "step": 0.1, "min": 0, "max": 20 },
			"global-margin-bottom": { "value": "1.5rem", "unit": "rem", "step": 0.1, "min": 0, "max": 20 },
			"global-padding-left": { "value": "1.5rem", "unit": "rem", "step": 0.1, "min": 0, "max": 20 },
			"global-padding-right": { "value": "1.5rem", "unit": "rem", "step": 0.1, "min": 0, "max": 20 },
			"global-padding-top": { "value": [".75rem", "1.5rem"], "unit": "rem", "step": 0.1, "min": 0, "max": 20, "suffixes": ["-small", "-large"], "labels": ["Small", "Large"] },
			"global-padding-bottom": { "value": [".75rem", "1.5rem"], "unit": "rem", "step": 0.1, "min": 0, "max": 20, "suffixes": ["-small", "-large"], "labels": ["Small", "Large"] },
			"global-": { "value": ["1.5rem", "1.5rem", "1.5rem", "1.5rem"], "unit": "rem", "step": 0.1, "min": 0, "max": 20, "suffixes": ["top-left-radius", "top-right-radius", "bottom-left-radius", "bottom-right-radius"], "labels": ["Top Left", "Top Right", "Bottom Left", "Bottom Right"] }
		},
		"colors": {
			"block-background": { "default": "#ffffff", "variant": "#F5F5F5", "variant2": "#1D548B" },
			"block-link": { "default": "#1D548B", "variant": "#1D548B", "variant2": "#8CBAE7" },
			"block-link-hover": { "default": "#1A4E7A", "variant": "#1A4E7A", "variant2": "#7AA9D0" },
			"block-link-active": { "default": "#163F5C", "variant": "#163F5C", "variant2": "#6680A8" }
		}
	}
}
